# ─── Investment Platform API — Environment Variables ───────────────────────────
#
# Copy this file to .env for local development (never commit .env).
# In production (Replit), set these as Secrets in the Replit Secrets panel.
#
# ─────────────────────────────────────────────────────────────────────────────

# Aiven PostgreSQL connection string (takes priority over DATABASE_URL).
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?sslmode=require
# Find this in your Aiven console → Services → <your service> → Overview → URI
AIVEN_DATABASE_URL=postgresql://avnadmin:your-password@your-host.aivencloud.com:28016/defaultdb?sslmode=require

# Set to "false" to disable SSL (only for local dev without SSL).
# Leave unset or set to "true" to enable SSL (required for Aiven).
# DATABASE_SSL=true

# Log verbosity: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Session secret for signed cookies (generate with: openssl rand -hex 32)
# SESSION_SECRET is already configured as a Replit Secret — no need to set it here.
